# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/lexguard?retryWrites=true&w=majority&appName=<appname>

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# Python AI Service
PYTHON_API_URL=http://localhost:8000

# File Upload
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=./uploads

# CORS
FRONTEND_URL=http://localhost:3000